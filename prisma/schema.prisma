// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum EventStatus {
  DRAFT
  PUBLISHED
  FINISHED
}

enum RegistrationStatus {
  REGISTERED
  CANCELLED
}

enum CheckInMethod {
  QR
  MANUAL
}

enum AdminRole {
  SUPER_ADMIN
  EVENT_MANAGER
  EVENT_STAFF
  USHER
}

enum MessageChannel {
  EMAIL
  WHATSAPP
}

enum MessageStatus {
  QUEUED
  SENT
  FAILED
}

enum FileType {
  PDF
  IMAGE
  VIDEO
  DOCUMENT
}

enum PointAction {
  BOOTH_VISIT
  COMPLETION_BONUS
  EARLY_BIRD_BONUS
  ADMIN_ADJUSTMENT
}

enum GiftTier {
  BRONZE
  SILVER
  GOLD
}

enum B2BMeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// CORE MODELS
// ============================================

// ============================================
// LOCATION MANAGEMENT
// ============================================

model Country {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique  // ISO 3166-1 alpha-2 (e.g., "EG", "TR")
  flagEmoji String?
  timezone  String   @default("UTC")
  
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id          String   @id @default(cuid())
  name        String
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  
  // Reusable City Content
  description     String?  @db.Text
  bannerImageUrl  String?
  attractions     Json?    // Array of { name, description, imageUrl, mapUrl }
  cafesAndFood    Json?    // Array of { name, cuisine, priceRange, address, mapUrl }
  transportation  Json?    // { airport, metro, taxi, tips }
  localTips       String?  @db.Text
  emergencyInfo   String?  @db.Text  // Police, hospitals, embassy contacts
  
  events      Event[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([countryId, name])
}

model Event {
  id                  String      @id @default(cuid())
  title               String
  slug                String      @unique
  // Location (new system)
  cityId              String?
  cityRef             City?       @relation(fields: [cityId], references: [id])
  
  // Legacy location fields (for backward compatibility)
  country             String?
  city                String?
  venueName           String
  venueAddress        String
  mapUrl              String?
  startDateTime       DateTime
  endDateTime         DateTime
  timezone            String      @default("UTC")
  bannerImageUrl      String?
  galleryImages       String[]
  description         String?     @db.Text
  
  // Multi-language content translations
  // Format: { "en": "...", "tr": "...", "ar": "..." }
  titleTranslations       Json?   // Translated titles
  descriptionTranslations Json?   // Translated descriptions
  
  // University Participation Pricing
  participationFee    Float?      // Fee for universities to join
  currency            String      @default("USD")
  
  registrationOpenAt  DateTime?
  registrationCloseAt DateTime?
  capacity            Int?
  status              EventStatus @default(DRAFT)
  createdById         String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Marketing Tracking Codes
  gaTrackingId        String?   // Google Analytics (e.g., G-XXXXXXX)
  fbPixelId           String?   // Facebook Pixel ID
  linkedInPartnerId   String?   // LinkedIn Insight Tag Partner ID
  tiktokPixelId       String?   // TikTok Pixel ID
  snapPixelId         String?   // Snapchat Pixel ID
  customHeadScript    String?   @db.Text // Custom <head> scripts
  customBodyScript    String?   @db.Text // Custom scripts before </body>

  // Zoho CRM Integration
  zohoCampaignId      String?   // Zoho Campaign ID for this event
  zohoLeadSource      String?   // Lead Source value

  // Red Points Configuration
  redPointsEnabled    Boolean   @default(false)
  pointsPerVisit      Int       @default(10)   // Points per booth visit
  completionBonus     Int       @default(50)   // Bonus for visiting ALL booths
  earlyBirdBonus      Int       @default(5)    // Bonus for first N visits
  earlyBirdCount      Int       @default(3)    // Number of visits for early bird
  bronzeThreshold     Int       @default(30)   // Points for Bronze tier
  silverThreshold     Int       @default(70)   // Points for Silver tier
  goldThreshold       Int       @default(100)  // Points for Gold tier

  createdBy     AdminUser            @relation(fields: [createdById], references: [id])
  universities  EventParticipating[]
  registrations Registration[]
  messageLogs   MessageLog[]
  reminderRules ReminderRule[]
  sessions      EventSession[]
  favorites     FavoriteStudent[]
  boothVisits   BoothVisit[]
  pointsLedger  RedPointsLedger[]
  giftRedemptions GiftRedemption[]
  b2bEvent      B2BEvent?
}

model EventSession {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  location    String?
  speaker     String?
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([eventId])
}

model University {
  id           String   @id @default(cuid())
  name         String
  logoUrl      String?
  website      String?
  country      String   @default("Unknown")
  city         String?
  description  String?  @db.Text
  contactEmail String?
  contactPhone String?
  programs     Json?    // Array of program names/types
  isActive     Boolean  @default(true)
  
  users        UniversityUser[]
  events       EventParticipating[]
  favorites    FavoriteStudent[]
  files        UniversityFile[]
  boothVisits  BoothVisit[]
  b2bParticipations B2BParticipant[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UniversityRole {
  ADMIN
  MEMBER
}

model UniversityUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         UniversityRole @default(ADMIN)
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  
  boothScans   BoothVisit[]  // Scans performed by this university user
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model EventParticipating {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  
  status       ParticipationStatus @default(INVITED)
  boothNumber  String?
  notes        String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([eventId, universityId])
}

enum ParticipationStatus {
  INVITED
  ACCEPTED
  DECLINED
  REQUESTED
}

model Registrant {
  id               String   @id @default(cuid())
  fullName         String
  email            String
  phone            String
  country          String
  city             String
  nationality      String?
  levelOfStudy     String?
  interestedMajor  String?
  standardizedMajor String? // AI-normalized major (e.g. Dentistry)
  majorCategory    String?  // AI-broad category (e.g. Health)
  gender           String?  // AI-inferred gender
  consentAccepted  Boolean
  consentTimestamp DateTime
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  registrations Registration[]
}

model Registration {
  id           String             @id @default(cuid())
  eventId      String
  registrantId String
  qrToken      String             @unique @default(cuid())
  status       RegistrationStatus @default(REGISTERED)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrant  Registrant         @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  checkIn     CheckIn?
  messageLogs MessageLog[]
  favorites   FavoriteStudent[]
  boothVisits BoothVisit[]
  pointsLedger RedPointsLedger[]
  giftRedemptions GiftRedemption[]

  @@unique([eventId, registrantId])
}

// University favorites - mark high-potential students at events
model FavoriteStudent {
  id             String   @id @default(cuid())
  eventId        String
  universityId   String
  registrationId String
  note           String?  @db.Text
  rating         Int      @default(0) // 0-5 star rating
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  university   University   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([eventId, universityId, registrationId])
  @@index([eventId, universityId])
}

model CheckIn {
  id             String        @id @default(cuid())
  registrationId String        @unique
  checkedInAt    DateTime      @default(now())
  checkedInById  String
  method         CheckInMethod

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  checkedInBy  AdminUser    @relation(fields: [checkedInById], references: [id])
}

model MessageLog {
  id                String         @id @default(cuid())
  eventId           String
  registrationId    String?
  channel           MessageChannel
  templateName      String
  providerMessageId String?
  status            MessageStatus  @default(QUEUED)
  errorText         String?
  createdAt         DateTime       @default(now())
  sentAt            DateTime?

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
}

model ReminderRule {
  id           String   @id @default(cuid())
  eventId      String
  reminderName String   // e.g., "Reminder #1", "Reminder #2"
  daysBefore   Int      // Days before event
  hoursBefore  Int?     // Hours before event (alternative to days)
  sendAtHour   Int      @default(9) // Hour of day to send (24h format)
  sendAtMinute Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ============================================
// AUTH MODELS
// ============================================

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String?
  role         AdminRole @default(EVENT_STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  accessCode   String?   @unique

  events              Event[]
  checkIns            CheckIn[]
  giftRedemptions     GiftRedemption[]  // Gifts redeemed by this admin/staff
  validatedDocuments  ValidatedDocument[]
  b2bEvents           B2BEvent[]
}

// ============================================
// MESSAGE TEMPLATES
// ============================================

model MessageTemplate {
  id          String         @id @default(cuid())
  name        String         @unique // e.g., "confirmation_email", "reminder_1_whatsapp"
  channel     MessageChannel
  subject     String?        // For emails
  body        String         @db.Text
  description String?
  isDefault   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

// ============================================
// PAPERLESS EVENTS — UNIVERSITY FILES
// ============================================

model UniversityFile {
  id           String     @id @default(cuid())
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  
  fileName     String     // Original file name
  fileUrl      String     // Supabase Storage URL
  fileType     FileType   @default(PDF)
  fileSize     Int        @default(0)   // Size in bytes
  label        String     // Display name (e.g., "2026 Programs Catalog")
  description  String?    @db.Text
  isActive     Boolean    @default(true)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@index([universityId])
}

// ============================================
// PAPERLESS EVENTS — BOOTH VISITS & RED POINTS
// ============================================

// Records when a university scans a student's QR at their booth
model BoothVisit {
  id              String          @id @default(cuid())
  eventId         String
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationId  String
  registration    Registration    @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  universityId    String
  university      University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  scannedById     String          // UniversityUser who scanned
  scannedBy       UniversityUser  @relation(fields: [scannedById], references: [id])
  
  pointsAwarded   Int             @default(0)
  note            String?         @db.Text  // Optional note from uni rep
  filesSentAt     DateTime?       // When brochures were sent/made available
  
  createdAt       DateTime        @default(now())
  
  // One visit per university per student per event
  @@unique([eventId, registrationId, universityId])
  @@index([eventId, universityId])
  @@index([eventId, registrationId])
}

// Ledger of all point transactions for a student at an event
model RedPointsLedger {
  id              String      @id @default(cuid())
  eventId         String
  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationId  String
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  
  action          PointAction
  points          Int         // Positive = earned, negative = spent/deducted
  referenceId     String?     // BoothVisit ID or other reference
  description     String?     // Human-readable description
  
  createdAt       DateTime    @default(now())
  
  @@index([eventId, registrationId])
}

// Gift redemption records
model GiftRedemption {
  id              String       @id @default(cuid())
  eventId         String
  event           Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationId  String
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  
  tier            GiftTier
  pointsAtRedemption Int       // Points balance at time of redemption
  redeemedById    String       // AdminUser (help desk staff) who processed
  redeemedBy      AdminUser    @relation(fields: [redeemedById], references: [id])
  
  createdAt       DateTime     @default(now())
  
  @@index([eventId])
  @@index([eventId, registrationId])
}

// ============================================
// DOCUMENT VALIDATION WITH QR
// ============================================

model ValidatedDocument {
  id              String    @id @default(cuid())
  token           String    @unique @default(cuid())  // QR lookup key
  referenceNumber String?   @unique                    // e.g. "LTR-2026-0042"
  subject         String                               // Letter subject
  recipientName   String?                              // "To whom"
  senderName      String?                              // Who signed
  senderTitle     String?                              // e.g. "Director"
  issuedAt        DateTime  @default(now())            // Date on the letter
  expiresAt       DateTime?                            // Optional expiry
  notes           String?   @db.Text                   // Extra context
  isRevoked       Boolean   @default(false)            // Can revoke if needed

  createdById     String
  createdBy       AdminUser @relation(fields: [createdById], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([token])
  @@index([referenceNumber])
}

// ============================================
// B2B MATCHMAKING SYSTEM
// ============================================

model B2BEvent {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  date                DateTime                    // Event date
  startTime           String                      // "10:00" — HH:mm format
  endTime             String                      // "16:00" — HH:mm format
  slotDuration        Int       @default(20)      // Minutes per meeting
  breakStart          String?                     // "12:00" — lunch break start
  breakEnd            String?                     // "13:00" — lunch break end
  location            String?
  description         String?   @db.Text
  isScheduleGenerated Boolean   @default(false)

  // Link to main Event (optional)
  eventId             String?   @unique
  event               Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdById         String
  createdBy           AdminUser @relation(fields: [createdById], references: [id])

  participants        B2BParticipant[]
  meetings            B2BMeeting[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model B2BParticipant {
  id              String    @id @default(cuid())
  b2bEventId      String
  b2bEvent        B2BEvent  @relation(fields: [b2bEventId], references: [id], onDelete: Cascade)

  side            String                      // "A" or "B"

  // For Side A — link to existing University
  universityId    String?
  university      University? @relation(fields: [universityId], references: [id])

  // For Side B — standalone data (no account)
  name            String                      // Company/Agent/School name
  contactPerson   String?
  contactEmail    String?
  contactPhone    String?
  organization    String?                     // Type: "Agent", "School", "Company"
  country         String?
  notes           String?   @db.Text
  arrivalTime     String?                     // "12:00" — HH:mm, null = available from start

  // Public schedule access token (Side B only)
  scheduleToken   String?   @unique @default(cuid())

  meetingsAsA     B2BMeeting[] @relation("MeetingSideA")
  meetingsAsB     B2BMeeting[] @relation("MeetingSideB")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([b2bEventId, universityId])
  @@index([b2bEventId, side])
}

model B2BMeeting {
  id              String           @id @default(cuid())
  b2bEventId      String
  b2bEvent        B2BEvent         @relation(fields: [b2bEventId], references: [id], onDelete: Cascade)

  participantAId  String                       // Side A (University)
  participantA    B2BParticipant   @relation("MeetingSideA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantBId  String                       // Side B (Agent/School/Company)
  participantB    B2BParticipant   @relation("MeetingSideB", fields: [participantBId], references: [id], onDelete: Cascade)

  timeSlot        DateTime                     // Exact start time of this meeting
  endTime         DateTime                     // Exact end time
  tableNumber     Int?                         // Physical table assignment

  status          B2BMeetingStatus @default(SCHEDULED)

  // Meeting notes (Side A can add)
  notesA          String?   @db.Text           // University notes
  notesB          String?   @db.Text           // Side B notes (future)

  // Document sharing tracking
  documentsSent   Boolean   @default(false)
  documentsSentAt DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([b2bEventId, participantAId, participantBId])  // No duplicate meetings
  @@unique([b2bEventId, participantAId, timeSlot])        // No double-booking Side A
  @@unique([b2bEventId, participantBId, timeSlot])        // No double-booking Side B
  @@index([b2bEventId])
}
